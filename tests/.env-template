# Environment for local docker testing of UMVC
#=============================================
# docker-related vars
HTTPS="off"
HTTP_PORT=7070
MYSQL_PORT=7072
TIMEZONE=Europe/Berlin

APPLICATION_ENV=develop
# Alternative to set real external base url
APP_BASEURL="http://umvc.local"
# FQDN Server name for apache web server and default certificate
SERVER_NAME="umvc.local"
APACHE_LOG_DIR=/app/tests/_output/runtime/logs

UMVC_DB_DSN=mysql:host=localhost;dbname=umvc-test
UMVC_DB_NAME=umvc-test
UMVC_DB_USER=umvc-test
UMVC_DB_PASSWORD=umvc-test123
