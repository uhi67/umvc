{
  "name": "uhi67/umvc",
  "description": "UMVC simple PHP framework",
  "type": "project",
  "homepage": "https://umvc.uhisoft.hu/",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "MIT",
  "authors": [
    {
      "name": "uhi67",
      "email": "uherkovich.peter@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-iconv": "*",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-mysqli": "*",
    "ext-openssl": "*",
    "ext-pdo_sqlite": "*",
    "ext-pdo": "*",
    "ext-simplexml": "*",
    "psr/log": "*"
  },
  "require-dev": {
    "codeception/codeception": "^5.2.1",
    "codeception/module-asserts": "^3.1.0",
    "php-webdriver/webdriver": "^1.0",
    "codeception/module-filesystem": "^3.0.1",
    "codeception/lib-innerbrowser": "^4.0.6",
    "codeception/module-rest": "^3.4.1",
    "phpmailer/phpmailer": "*",
    "simplesamlphp/simplesamlphp": "*"
  },
  "suggest": {
    "phpmailer/phpmailer": "*",
    "simplesamlphp/simplesamlphp": "*"
  },
  "scripts": {
  },
  "autoload": {
    "psr-4": {
      "uhi67\\umvc\\commands\\": "commands",
      "uhi67\\umvc\\models\\": "models",
      "uhi67\\umvc\\": "lib"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Helper\\": "lib/testhelper",
      "testapp\\": "tests/_data/testapp",
      "tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.2"
    }
  }
}
