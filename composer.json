{
  "name": "educalliance/umvc",
  "description": "UMVC simple PHP framework",
  "type": "project",
  "homepage": "https://educalliance.eu/",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "MIT",
  "authors": [
    {
      "name": "Uherkovich Péter",
      "email": "uherkovich.peter@pte.hu"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-iconv": "*",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-mysqli": "*",
    "ext-openssl": "*",
    "ext-pdo_sqlite": "*",
    "ext-pdo": "*",
    "ext-simplexml": "*",
    "psr/log": "*"
  },
  "require-dev": {
    "codeception/codeception": "^5.2.1",
    "codeception/module-asserts": "^3.1.0",
    "php-webdriver/webdriver": "^1.0",
    "codeception/module-filesystem": "^3.0.1",
    "codeception/lib-innerbrowser": "^4.0.6",
    "codeception/module-rest": "^3.4.1",
    "simplesamlphp/simplesamlphp": "*",
    "phpmailer/phpmailer": "*"
  },
  "suggest": {
    "simplesamlphp/simplesamlphp": "*",
    "phpmailer/phpmailer": "*"
  },
  "scripts": {
  },
  "autoload": {
    "psr-4": {
      "educalliance\\umvc\\commands\\": "commands",
      "educalliance\\umvc\\models\\": "models",
      "educalliance\\umvc\\": "lib"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Helper\\": "lib/testhelper"
    }
  },
  "config": {
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "simplesamlphp/composer-xmlprovider-installer": true,
      "simplesamlphp/composer-module-installer": true
    }
  }
}
